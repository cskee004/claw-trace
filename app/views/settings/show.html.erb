<% content_for(:title) { "Settings" } %>

<div class="p-4">
  <h1 class="text-xl font-bold text-[var(--color-fg)] mb-6">Settings</h1>

  <% if flash[:notice] %>
    <p class="flash flash--notice px-4 py-2 rounded text-sm mb-4"><%= flash[:notice] %></p>
  <% end %>
  <% if flash[:alert] %>
    <p class="flash flash--alert px-4 py-2 rounded text-sm mb-4"><%= flash[:alert] %></p>
  <% end %>

  <%# ── Data Retention ── %>
  <div class="bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg overflow-hidden mb-6">
    <div class="px-4 py-3 border-b border-[var(--color-surface-2)]">
      <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]">Data Retention</h2>
    </div>

    <div class="px-4 py-4">

      <%# ── Logs ── %>
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">Logs</p>

      <%= form_with url: settings_path, method: :patch, class: "flex items-center gap-3 mb-3" do %>
        <input type="hidden" name="setting_key" value="log_retention_days">
        <label class="text-sm text-[var(--color-fg)]" for="log_retention_days">
          Delete log records older than
        </label>
        <input type="number"
               id="log_retention_days"
               name="setting_value"
               value="<%= @log_retention_days %>"
               min="1"
               max="3650"
               required
               class="w-20 text-sm font-mono bg-[var(--color-bg)] border border-[var(--color-surface-2)]
                      text-[var(--color-fg)] rounded px-2.5 py-1.5
                      focus:outline-none focus:border-[var(--color-accent)]">
        <span class="text-sm text-[var(--color-fg)]">days</span>
        <button type="submit"
                class="text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                       text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80">
          Save
        </button>
      <% end %>

      <div class="flex items-center gap-2">
        <%= button_to "Prune Logs Now",
              prune_logs_settings_path,
              method: :post,
              class: "text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                      text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80",
              data: { turbo_confirm: "Delete all log records older than the configured retention window? This cannot be undone." } %>
        <%= button_to "Delete All Logs",
              delete_all_logs_settings_path,
              method: :post,
              class: "btn--danger",
              data: { turbo_confirm: "Delete ALL log records? This cannot be undone." } %>
      </div>

      <%# ── Traces ── %>
      <div class="border-t border-[var(--color-surface-2)] mt-4 pt-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">Traces</p>

        <%= form_with url: settings_path, method: :patch, class: "flex items-center gap-3 mb-3" do %>
          <input type="hidden" name="setting_key" value="trace_retention_days">
          <label class="text-sm text-[var(--color-fg)]" for="trace_retention_days">
            Delete trace records older than
          </label>
          <input type="number"
                 id="trace_retention_days"
                 name="setting_value"
                 value="<%= @trace_retention_days %>"
                 min="1"
                 max="3650"
                 required
                 class="w-20 text-sm font-mono bg-[var(--color-bg)] border border-[var(--color-surface-2)]
                        text-[var(--color-fg)] rounded px-2.5 py-1.5
                        focus:outline-none focus:border-[var(--color-accent)]">
          <span class="text-sm text-[var(--color-fg)]">days</span>
          <button type="submit"
                  class="text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                         text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80">
            Save
          </button>
        <% end %>

        <div class="flex items-center gap-2">
          <%= button_to "Prune Traces Now",
                prune_traces_settings_path,
                method: :post,
                class: "text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                        text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80",
                data: { turbo_confirm: "Delete all trace records (and their spans) older than the configured retention window? This cannot be undone." } %>
          <%= button_to "Delete All Traces",
                delete_all_traces_settings_path,
                method: :post,
                class: "btn--danger",
                data: { turbo_confirm: "Delete ALL trace records and their spans? This cannot be undone." } %>
        </div>
        <p class="mt-2 text-xs text-[var(--color-fg-subtle)]">Includes associated spans. Logs are managed separately.</p>
      </div>

      <%# ── Metrics ── %>
      <div class="border-t border-[var(--color-surface-2)] mt-4 pt-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)] mb-3">Metrics</p>

        <%= form_with url: settings_path, method: :patch, class: "flex items-center gap-3 mb-3" do %>
          <input type="hidden" name="setting_key" value="metric_retention_days">
          <label class="text-sm text-[var(--color-fg)]" for="metric_retention_days">
            Delete metric records older than
          </label>
          <input type="number"
                 id="metric_retention_days"
                 name="setting_value"
                 value="<%= @metric_retention_days %>"
                 min="1"
                 max="3650"
                 required
                 class="w-20 text-sm font-mono bg-[var(--color-bg)] border border-[var(--color-surface-2)]
                        text-[var(--color-fg)] rounded px-2.5 py-1.5
                        focus:outline-none focus:border-[var(--color-accent)]">
          <span class="text-sm text-[var(--color-fg)]">days</span>
          <button type="submit"
                  class="text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                         text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80">
            Save
          </button>
        <% end %>

        <div class="flex items-center gap-2">
          <%= button_to "Prune Metrics Now",
                prune_metrics_settings_path,
                method: :post,
                class: "text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                        text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80",
                data: { turbo_confirm: "Delete all metric records older than the configured retention window? This cannot be undone." } %>
          <%= button_to "Delete All Metrics",
                delete_all_metrics_settings_path,
                method: :post,
                class: "btn--danger",
                data: { turbo_confirm: "Delete ALL metric records? This cannot be undone." } %>
        </div>
      </div>

    </div>
  </div>
</div>
