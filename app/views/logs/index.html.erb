<% content_for(:title) { "Logs" } %>

<div class="p-4">
  <turbo-frame id="log_list">
    <form class="flex items-center gap-2 flex-wrap mb-5"
          action="<%= logs_path %>" method="get">

      <label class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]"
             for="severity">Severity</label>
      <select name="severity" id="severity"
              class="text-sm bg-[var(--color-surface)] border border-[var(--color-surface-2)]
                     text-[var(--color-fg)] rounded px-2.5 py-1.5
                     focus:outline-none focus:border-[var(--color-accent)]">
        <option value="">All</option>
        <% %w[DEBUG INFO WARN ERROR FATAL].each do |level| %>
          <option value="<%= level %>" <%= "selected" if @severity == level %>><%= level %></option>
        <% end %>
      </select>

      <% if @subsystems.any? %>
        <label class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]"
               for="subsystem">Subsystem</label>
        <select name="subsystem" id="subsystem"
                class="text-sm bg-[var(--color-surface)] border border-[var(--color-surface-2)]
                       text-[var(--color-fg)] rounded px-2.5 py-1.5
                       focus:outline-none focus:border-[var(--color-accent)]">
          <option value="">All</option>
          <% @subsystems.each do |sub| %>
            <option value="<%= sub %>" <%= "selected" if @subsystem == sub %>><%= sub %></option>
          <% end %>
        </select>
      <% end %>

      <label class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]"
             for="trace_id">Trace ID</label>
      <input class="font-mono text-sm bg-[var(--color-surface)] border border-[var(--color-surface-2)]
                    text-[var(--color-fg)] rounded px-2.5 py-1.5 w-44
                    focus:outline-none focus:border-[var(--color-accent)]
                    placeholder:text-[var(--color-fg-subtle)]"
             type="text" id="trace_id" name="trace_id"
             value="<%= params[:trace_id] %>"
             placeholder="Filter by trace ID…">

      <button class="text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)]
                     text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80"
              type="submit">Filter</button>

      <% if @severity.present? || @trace_id.present? || @subsystem.present? %>
        <%= link_to "Clear", logs_path,
              class: "text-xs text-[var(--color-fg-subtle)] hover:text-[var(--color-fg)]" %>
      <% end %>
    </form>

    <% if @logs.empty? %>
      <%= render "shared/connect_openclaw" %>
    <% else %>
      <div class="rounded-lg overflow-hidden border border-[var(--color-surface-2)]">
        <table class="w-full border-collapse bg-[var(--color-surface)]">
          <thead>
            <tr>
              <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)] whitespace-nowrap">Timestamp</th>
              <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Severity</th>
              <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Message</th>
              <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Trace</th>
              <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Span</th>
            </tr>
          </thead>
          <% @logs.each do |log| %>
            <%= render "logs/log_row", log: log, timestamp_fmt: "%b %-d %H:%M:%S.%3N" %>
          <% end %>
        </table>
      </div>
      <p class="mt-3 text-xs text-[var(--color-fg-subtle)] text-right">
        Showing last <%= @logs.size %> records
      </p>
    <% end %>
  </turbo-frame>
</div>
