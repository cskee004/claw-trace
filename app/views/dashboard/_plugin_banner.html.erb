<%# Onboarding banner — shown when >90% of last-24h traces are single-span,
    suggesting the @clawtrace-io/clawtails plugin is not installed. %>
<div class="flex items-center gap-3 border border-[var(--color-warn-fg)] rounded-lg px-4 py-3 mb-6
            bg-[var(--color-warn-bg)] text-sm text-[var(--color-fg-muted)]">
  <span class="text-[var(--color-warn-fg)] font-bold text-xs uppercase tracking-widest shrink-0">Tip</span>
  <span>
    Install the <strong class="text-[var(--color-fg)]">ClawTrace plugin for OpenClaw</strong>
    to enable the full waterfall view with parent-child span hierarchy.
    Run <code class="font-mono text-xs bg-[var(--color-surface-2)] px-1 rounded">openclaw plugins install @clawtrace-io/clawtails</code>
    to get started.
  </span>
</div>
