<%# app/views/dashboard/index.html.erb %>
<% content_for(:title) { "Dashboard" } %>

<div class="p-4">
  <%= render "plugin_banner" if @show_plugin_banner %>

  <%# ── Stat strip ── %>
  <div class="flex flex-wrap gap-6 bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4 mb-6">
    <div class="flex flex-col gap-0.5">
      <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Total Traces</span>
      <span class="font-mono text-2xl font-bold text-[var(--color-fg)]"><%= @total_traces %></span>
    </div>
    <div class="flex flex-col gap-0.5">
      <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Active Agents</span>
      <span class="font-mono text-2xl font-bold text-[var(--color-fg)]"><%= @active_agents %></span>
    </div>
    <div class="flex flex-col gap-0.5">
      <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Error Rate (<%= @period_label %>)</span>
      <span class="font-mono text-2xl font-bold <%= @error_rate_30d > 0 ? 'text-[var(--color-span-error)]' : 'text-[var(--color-success-fg)]' %>">
        <%= @error_rate_30d %>%
      </span>
    </div>
  </div>

  <%# ── Token strip ── %>
  <% if @token_stats[:total_tokens] > 0 %>
    <div class="flex flex-wrap gap-6 bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4 mb-6">
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Total Tokens (<%= @period_label %>)</span>
        <span class="font-mono text-2xl font-bold text-[var(--color-fg)]"><%= number_with_delimiter(@token_stats[:total_tokens]) %></span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Input</span>
        <span class="font-mono text-2xl font-bold text-[var(--color-fg-muted)]"><%= number_with_delimiter(@token_stats[:input_tokens]) %></span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Output</span>
        <span class="font-mono text-2xl font-bold text-[var(--color-fg-muted)]"><%= number_with_delimiter(@token_stats[:output_tokens]) %></span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Cache Read</span>
        <span class="font-mono text-2xl font-bold text-[var(--color-fg-muted)]"><%= number_with_delimiter(@token_stats[:cache_read_tokens]) %></span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Cache Write</span>
        <span class="font-mono text-2xl font-bold text-[var(--color-fg-muted)]"><%= number_with_delimiter(@token_stats[:cache_write_tokens]) %></span>
      </div>
      <% if @token_stats[:cache_hit_ratio] %>
        <div class="flex flex-col gap-0.5">
          <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">Cache Hit Ratio</span>
          <span class="font-mono text-2xl font-bold text-[var(--color-success-fg)]"><%= @token_stats[:cache_hit_ratio] %>%</span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Metric tiles (agent turns + tool errors from OTLP metrics stream) ── %>
  <% if @metric_stats.any? %>
    <div class="flex flex-wrap gap-6 bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4 mb-6">
      <% @metric_stats.each do |name, stats| %>
        <div class="flex flex-col gap-0.5">
          <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-fg-subtle)]">
            <%= name == "agent.turns.total" ? "Agent Turns" : "Tool Errors" %> (<%= @period_label %>)
          </span>
          <div class="flex items-baseline gap-2">
            <span class="font-mono text-2xl font-bold text-[var(--color-fg)]"><%= number_with_delimiter(stats[:total]) %></span>
            <% if (d = stats[:delta_pct]) %>
              <span class="font-mono text-[11px] font-bold <%= d >= 0 ? 'text-[var(--color-warn-fg)]' : 'text-[var(--color-success-fg)]' %>">
                <%= d >= 0 ? "▲" : "▼" %>&nbsp;<%= d.abs %>%
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Period filter ── %>
  <div class="flex items-center gap-2 flex-wrap mb-6"
       data-controller="dashboard-filter">
    <% [["12h", "12h"], ["24h", "24h"], ["7d", "7d"], ["30d", "30d"]].each do |period, label| %>
      <%= link_to label, dashboard_path(period: period),
            class: "filter-btn #{'filter-btn--active' if @current_period == period}" %>
    <% end %>
    <button type="button"
            class="filter-btn <%= 'filter-btn--active' if @current_period == 'custom' %>"
            data-action="click->dashboard-filter#showCustom">
      Custom
    </button>

    <form data-dashboard-filter-target="customForm"
          <%= @current_period == "custom" ? "" : "hidden" %>
          action="<%= dashboard_path %>" method="get"
          class="flex items-center gap-2">
      <input type="hidden" name="period" value="custom">
      <input type="date" name="from" value="<%= params[:from] %>"
             class="date-input" required>
      <span class="text-xs text-[var(--color-fg-subtle)]">to</span>
      <input type="date" name="to" value="<%= params[:to] %>"
             class="date-input" required>
      <button type="submit" class="filter-btn">Apply</button>
    </form>
  </div>

  <%# ── Chart grid ── %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4">
      <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">
        Error Rate — <%= @period_label %>
      </h2>
      <turbo-frame id="dashboard_error_rate_chart"
                   src="<%= error_rate_chart_dashboard_index_path(period: @current_period, from: params[:from], to: params[:to]) %>"
                   loading="lazy">
        <div class="min-h-[240px] flex items-center justify-center
                    text-xs italic text-[var(--color-fg-subtle)]">Loading…</div>
      </turbo-frame>
    </div>
    <div class="bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4">
      <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">
        Traces — <%= @period_label %>
      </h2>
      <turbo-frame id="dashboard_traces_volume_chart"
                   src="<%= traces_volume_chart_dashboard_index_path(period: @current_period, from: params[:from], to: params[:to]) %>"
                   loading="lazy">
        <div class="min-h-[240px] flex items-center justify-center
                    text-xs italic text-[var(--color-fg-subtle)]">Loading…</div>
      </turbo-frame>
    </div>
  </div>
</div>
