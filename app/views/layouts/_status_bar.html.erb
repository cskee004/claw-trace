<%# Nav sidebar status indicator — log-based activity heartbeat %>
<div class="status-bar">
  <span class="status-bar__dot status-bar__dot--<%= status_bar[:live] ? 'live' : 'idle' %>"></span>
  <% if status_bar[:last_log_at] %>
    <span class="status-bar__label"><%= status_bar[:live] ? 'Live' : 'Idle' %></span>
    <span class="status-bar__text"><%= format_time_relative(status_bar[:last_log_at]) %></span>
  <% else %>
    <span class="status-bar__label">No logs</span>
  <% end %>
</div>
