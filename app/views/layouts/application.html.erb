<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ClawTrace" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

    <%# Tailwind loads first; existing custom stylesheets can override during transition %>
    <%= stylesheet_link_tag "tailwind", "application", "base", "layout", "module", "state", "theme", "data-turbo-track": Rails.env.production? ? "reload" : "" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
    <script>
      document.addEventListener("turbo:load", () => lucide.createIcons());
      document.addEventListener("DOMContentLoaded", () => lucide.createIcons());
    </script>
  </head>

  <body class="bg-[var(--color-bg)] text-[var(--color-fg)] font-sans antialiased">
    <div id="container">
      <div id="logo">
        <span style="color: var(--color-accent);">Claw</span><span style="color: var(--color-fg-subtle);">Trace</span>
      </div>
      <div id="header">
        <% if content_for?(:breadcrumbs) %>
          <%= yield :breadcrumbs %>
        <% elsif content_for?(:title) %>
          <span class="text-sm font-bold text-[var(--color-fg)]"><%= yield :title %></span>
        <% end %>
      </div>
      <div id="nav">
        <%= link_to traces_path, class: "nav-link #{'nav-link--active' if controller_name == 'traces'}" do %>
          <i data-lucide="activity"></i>Traces
        <% end %>
        <%= link_to agents_path, class: "nav-link #{'nav-link--active' if controller_name == 'agents'}" do %>
          <i data-lucide="bot"></i>Agents
        <% end %>
        <%= link_to metrics_path, class: "nav-link #{'nav-link--active' if controller_name == 'metrics'}" do %>
          <i data-lucide="bar-chart-2"></i>Metrics
        <% end %>
        <%= link_to logs_path, class: "nav-link #{'nav-link--active' if controller_name == 'logs'}" do %>
          <i data-lucide="scroll-text"></i>Logs
        <% end %>
        <%= link_to dashboard_path, class: "nav-link #{'nav-link--active' if controller_name == 'dashboard'}" do %>
          <i data-lucide="layout-dashboard"></i>Dashboard
        <% end %>
        <div style="margin-top: auto;">
          <%= link_to settings_path, class: "nav-link #{'nav-link--active' if controller_name == 'settings'}" do %>
            <i data-lucide="settings"></i>Settings
          <% end %>
        </div>
      </div>
      <div id="main">
        <%= yield %>
      </div>
      <div id="footer"></div>
    </div>
  </body>
</html>
