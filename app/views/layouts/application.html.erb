<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ClawTrace" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

    <%# Tailwind loads first; existing custom stylesheets can override during transition %>
    <%= stylesheet_link_tag "tailwind", "application", "base", "layout", "module", "state", "theme", "data-turbo-track": Rails.env.production? ? "reload" : "" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[var(--color-bg)] text-[var(--color-fg)] font-sans antialiased">
    <div id="container">
      <div id="header">
        <div id="logo">ClawTrace</div>
      </div>
      <div id="nav">
        <%= link_to 'Dashboard', dashboard_path,  class: "nav-link #{'nav-link--active' if controller_name == 'dashboard'}" %>
        <%= link_to 'Agents',    agents_path,     class: "nav-link #{'nav-link--active' if controller_name == 'agents'}" %>
        <%= link_to 'Traces',    traces_path,     class: "nav-link #{'nav-link--active' if controller_name == 'traces'}" %>
        <%= link_to 'Metrics',   metrics_path,    class: "nav-link #{'nav-link--active' if controller_name == 'metrics'}" %>
      </div>
      <div id="main">
        <%= yield %>
      </div>
      <div id="footer"></div>
    </div>
  </body>
</html>
