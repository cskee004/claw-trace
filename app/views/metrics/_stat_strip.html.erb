<%# app/views/metrics/_stat_strip.html.erb
    Locals:
      chart_stats: Hash or nil  — stat data from MetricChartBuilder
      mb:          String       — Tailwind margin-bottom class, e.g. "mb-3" or "mb-4"
%>
<% if chart_stats %>
  <div class="flex flex-wrap gap-6 <%= mb %>">
    <div class="flex items-baseline gap-1.5">
      <span class="text-xs text-[var(--color-fg-muted)]">Total</span>
      <span class="font-mono text-sm font-bold text-[var(--color-fg)]">
        <%= number_with_delimiter(chart_stats[:total]&.round(2)) %>
      </span>
    </div>
    <% if chart_stats[:series_count].to_i > 1 %>
      <div class="flex items-baseline gap-1.5">
        <span class="text-xs text-[var(--color-fg-muted)]">Series</span>
        <span class="font-mono text-sm font-bold text-[var(--color-fg)]"><%= chart_stats[:series_count] %></span>
      </div>
    <% end %>
    <% if chart_stats[:latest_timestamp] %>
      <div class="flex items-baseline gap-1.5">
        <span class="text-xs text-[var(--color-fg-muted)]">Updated</span>
        <span class="font-mono text-xs text-[var(--color-fg-muted)]">
          <%= time_ago_in_words(chart_stats[:latest_timestamp]) %> ago
        </span>
      </div>
    <% end %>
  </div>
<% end %>
