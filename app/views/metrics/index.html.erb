<%# app/views/metrics/index.html.erb %>
<% content_for(:title) { "Metrics" } %>

<div class="metrics-page">
  <div class="metrics-header">
    <h1 class="page-title">Metrics</h1>
  </div>

  <%= form_with url: metrics_path, method: :get, local: true, class: "metrics-filter" do |f| %>
    <%= f.text_field :q,        value: params[:q],        placeholder: "Name…",     class: "metrics-filter__input" %>
    <%= f.text_field :model,    value: params[:model],    placeholder: "Model…",    class: "metrics-filter__input" %>
    <%= f.text_field :provider, value: params[:provider], placeholder: "Provider…", class: "metrics-filter__input" %>
    <%= f.text_field :channel,  value: params[:channel],  placeholder: "Channel…",  class: "metrics-filter__input" %>
    <%= f.submit "Filter", class: "metrics-filter__submit" %>
    <% if [params[:q], params[:model], params[:provider], params[:channel]].any?(&:present?) %>
      <%= link_to "Clear", metrics_path, class: "reset-link" %>
    <% end %>
  <% end %>

  <% if @chart_cards.empty? %>
    <p class="metrics-empty">No metrics recorded yet.</p>
  <% else %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
      <% @chart_cards.each do |card| %>
        <div class="bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="font-mono text-sm font-bold text-[var(--color-fg)]">
              <%= card[:metric_name] %>
            </span>
            <span class="metric-type-badge metric-type-badge--<%= card[:metric_type] %>">
              <%= card[:metric_type] %>
            </span>
          </div>
          <div class="min-h-[320px]"
               data-controller="chart"
               data-chart-options-value="<%= json_escape(card[:options].to_json) %>">
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
