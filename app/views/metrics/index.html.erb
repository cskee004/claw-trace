<%# app/views/metrics/index.html.erb %>
<% content_for(:title) { "Metrics" } %>

<div class="metrics-page">
  <%= form_with url: metrics_path, method: :get, local: true, class: "metrics-filter" do |f| %>
    <%= f.text_field :q,        value: params[:q],        placeholder: "Name…",     class: "metrics-filter__input" %>
    <%= f.text_field :model,    value: params[:model],    placeholder: "Model…",    class: "metrics-filter__input" %>
    <%= f.text_field :provider, value: params[:provider], placeholder: "Provider…", class: "metrics-filter__input" %>
    <%= f.text_field :channel,  value: params[:channel],  placeholder: "Channel…",  class: "metrics-filter__input" %>
    <%= f.submit "Filter", class: "metrics-filter__submit" %>
    <% if [params[:q], params[:model], params[:provider], params[:channel]].any?(&:present?) %>
      <%= link_to "Clear", metrics_path, class: "reset-link" %>
    <% end %>
  <% end %>

  <% if @summaries.empty? %>
    <%= render "shared/connect_openclaw" %>
  <% else %>
    <div class="rounded-lg overflow-hidden border border-[var(--color-surface-2)] mt-4">
      <table class="w-full border-collapse bg-[var(--color-surface)]">
        <thead>
          <tr>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Metric</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Type</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-right bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Value</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-right bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Series</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-right bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Updated</th>
          </tr>
        </thead>
        <tbody>
          <% @summaries.each do |s| %>
            <tr class="border-b border-[var(--color-surface-2)] last:border-0
                       hover:bg-[var(--color-row-hover)]">
              <td class="px-4 py-3 align-middle">
                <%= link_to s[:metric_name], metric_path(s[:metric_name]),
                      class: "font-mono text-xs text-[var(--color-accent)] hover:underline" %>
              </td>
              <td class="px-4 py-3 align-middle">
                <span class="metric-type-badge metric-type-badge--<%= s[:metric_type] %>">
                  <%= s[:metric_type] %>
                </span>
              </td>
              <td class="px-4 py-3 align-middle text-right font-mono text-sm font-bold text-[var(--color-fg)]">
                <% if s[:metric_type] == "histogram" %>
                  <span class="text-xs">P50 </span><%= s[:value][:p50]&.round(1) || "—" %>
                  <span class="text-[var(--color-fg-subtle)] text-[10px] ml-2">(<%= number_with_delimiter(s[:value][:count]) %> ops)</span>
                <% else %>
                  <%= number_with_delimiter(s[:value].round(2)) %>
                <% end %>
              </td>
              <td class="px-4 py-3 align-middle text-right text-xs text-[var(--color-fg-subtle)]">
                <%= s[:series_count] %>
              </td>
              <td class="px-4 py-3 align-middle text-right text-[11px] text-[var(--color-fg-subtle)] whitespace-nowrap">
                <%= time_ago_in_words(s[:updated_at]) %> ago
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-[var(--color-fg-subtle)] text-right">
      <%= pluralize(@summaries.size, "metric") %> · click a name for the per-attribute breakdown
    </p>
  <% end %>
</div>
