<%# app/views/metrics/show.html.erb %>
<% content_for(:title) { @metric_name } %>
<% content_for(:breadcrumbs) do %>
  <nav class="flex items-center gap-2 text-sm">
    <%= link_to "Metrics", metrics_path, class: "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]" %>
    <span class="text-[var(--color-fg-subtle)] font-light">/</span>
    <span class="font-mono font-bold text-[var(--color-fg)] truncate"><%= @metric_name %></span>
  </nav>
<% end %>

<div class="metrics-show">
  <div class="metrics-show__header">
    <div class="metrics-show__title-row">
      <h1 class="page-title"><%= @metric_name %></h1>
      <% if @metric_type %>
        <span class="metric-type-badge metric-type-badge--<%= @metric_type %>">
          <%= @metric_type %>
        </span>
      <% end %>
    </div>
  </div>

  <% if @has_data %>
    <%= render "metrics/stat_strip", chart_stats: @chart_stats, mb: "mb-4" %>
    <div class="metrics-show__chart-wrapper"
         data-controller="apex-chart"
         data-apex-chart-options-value="<%= json_escape(@chart_options.to_json) %>">
    </div>
  <% else %>
    <p class="metrics-empty">No data recorded for this metric.</p>
  <% end %>
</div>
