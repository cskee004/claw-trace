<%# app/views/metrics/show.html.erb %>
<% content_for(:title) { @metric_name } %>

<div class="metrics-show">
  <div class="metrics-show__header">
    <%= link_to "← All Metrics", metrics_path, class: "metrics-show__back" %>
    <div class="metrics-show__title-row">
      <h1 class="page-title"><%= @metric_name %></h1>
      <% if @metric_type %>
        <span class="metric-type-badge metric-type-badge--<%= @metric_type %>">
          <%= @metric_type %>
        </span>
      <% end %>
    </div>
  </div>

  <% if @has_data %>
    <% if @chart_stats %>
      <div class="flex gap-6 mb-4">
        <% if @chart_stats[:type] == "sum" %>
          <div class="flex items-baseline gap-1.5">
            <span class="text-xs text-[var(--color-fg-muted)]">Latest</span>
            <span class="font-mono text-sm font-bold text-[var(--color-fg)]"><%= @chart_stats[:latest_value]&.round(4) %></span>
          </div>
          <div class="flex items-baseline gap-1.5">
            <span class="text-xs text-[var(--color-fg-muted)]">At</span>
            <span class="font-mono text-xs text-[var(--color-fg-muted)]"><%= @chart_stats[:latest_timestamp]&.strftime("%H:%M %Z") %></span>
          </div>
        <% elsif @chart_stats[:type] == "histogram" %>
          <% [[:p50, "P50"], [:p95, "P95"], [:p99, "P99"]].each do |key, label| %>
            <div class="flex items-baseline gap-1.5">
              <span class="text-xs text-[var(--color-fg-muted)]"><%= label %></span>
              <span class="font-mono text-sm font-bold text-[var(--color-fg)]"><%= @chart_stats[key]&.round(1) %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <div class="metrics-show__chart-wrapper"
         data-controller="chart"
         data-chart-options-value="<%= json_escape(@chart_options.to_json) %>">
    </div>
  <% else %>
    <p class="metrics-empty">No data recorded for this metric.</p>
  <% end %>
</div>
