<% content_for(:title) { "Agent Traces" } %>

<div class="flex items-center justify-between mb-5">
  <h1 class="text-xl font-bold text-[var(--color-fg)]">Agent Traces</h1>
</div>

<% if flash[:notice] %>
  <p class="flash flash--notice px-4 py-2 rounded text-sm mb-4"><%= flash[:notice] %></p>
<% end %>
<% if flash[:alert] %>
  <p class="flash flash--alert px-4 py-2 rounded text-sm mb-4"><%= flash[:alert] %></p>
<% end %>

<turbo-frame id="trace_list">
  <form class="flex items-center gap-2 flex-wrap mb-5"
        action="<%= traces_path %>" method="get">
    <label class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]"
           for="session_id">Session ID</label>
    <input class="font-mono text-sm bg-[var(--color-surface)] border border-[var(--color-surface-2)] text-[var(--color-fg)] rounded px-2.5 py-1.5 w-56 focus:outline-none focus:border-[var(--color-accent)] placeholder:text-[var(--color-fg-subtle)]"
           type="text" id="session_id" name="session_id"
           value="<%= params[:session_id] %>"
           placeholder="Filter by agent.session.id…">
    <button class="text-xs font-bold px-3 py-1.5 bg-[var(--color-surface-2)] text-[var(--color-fg)] rounded cursor-pointer hover:opacity-80"
            type="submit">Filter</button>
    <% if params[:session_id].present? %>
      <%= link_to "Clear", traces_path,
            class: "text-xs text-[var(--color-fg-subtle)] hover:text-[var(--color-fg)]" %>
    <% end %>
  </form>

  <% if @traces.empty? %>
    <%= render "shared/connect_openclaw" %>
  <% else %>
    <div class="rounded-lg overflow-hidden border border-[var(--color-surface-2)]">
      <table class="w-full border-collapse bg-[var(--color-surface)]">
        <thead>
          <tr>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Trace ID</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Agent</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Task</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Start Time</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Duration</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Status</th>
            <th class="w-8 bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]"></th>
          </tr>
        </thead>

        <% @traces.each do |trace| %>
          <tbody data-controller="trace-row"
                 data-trace-row-preview-url-value="<%= preview_trace_path(trace) %>">

            <%# ── Data row ── %>
            <tr class="border-b border-[var(--color-surface-2)] cursor-pointer"
                data-action="click->trace-row#toggle"
                onmouseover="this.style.backgroundColor='var(--color-row-hover)'"
                onmouseout="this.style.backgroundColor=''">
              <td class="px-4 py-2.5 align-middle">
                <%= link_to trace.trace_id, trace_path(trace),
                      class: "font-mono text-xs text-[var(--color-accent)] hover:underline",
                      data: { turbo_frame: "_top" } %>
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs text-[var(--color-fg-muted)]">
                <%= trace.agent_id %>
              </td>
              <td class="px-4 py-2.5 align-middle text-sm font-medium text-[var(--color-fg)]">
                <%= trace.task_name %>
              </td>
              <td class="px-4 py-2.5 align-middle">
                <span class="block text-xs font-medium text-[var(--color-fg-muted)]">
                  <%= format_time_relative(trace.start_time) %>
                </span>
                <span class="block font-mono text-[10px] text-[var(--color-fg-subtle)]">
                  <%= format_time_absolute(trace.start_time) %>
                </span>
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs text-[var(--color-fg-muted)]">
                <%= format_duration(@durations[trace.trace_id]) %>
              </td>
              <td class="px-4 py-2.5 align-middle">
                <span class="status-badge status-badge--<%= trace.status %>
                             inline-block px-2 py-0.5 rounded text-xs font-bold tracking-wide capitalize">
                  <%= trace.status.tr("_", " ") %>
                </span>
              </td>
              <td class="px-2 py-2.5 align-middle text-right">
                <button type="button"
                        class="font-mono text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]
                               focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent)]
                               cursor-pointer w-6 text-center rounded"
                        data-trace-row-target="chevron"
                        data-action="click->trace-row#toggle"
                        aria-expanded="false"
                        aria-controls="drawer_<%= trace.trace_id %>"
                        aria-label="Expand trace preview">▼</button>
              </td>
            </tr>

            <%# ── Drawer row (hidden until expanded) ── %>
            <tr id="drawer_<%= trace.trace_id %>"
                class="trace-row-drawer border-b border-[var(--color-surface-2)] last:border-0"
                data-trace-row-target="drawer">
              <td colspan="7" class="p-0">
                <div class="trace-row-drawer__content">
                  <turbo-frame id="trace_preview_<%= trace.trace_id %>"
                               data-trace-row-target="frame">
                    <div class="px-4 py-3 text-xs text-[var(--color-fg-subtle)] italic">Loading…</div>
                  </turbo-frame>
                </div>
              </td>
            </tr>

          </tbody>
        <% end %>
      </table>
    </div>
  <% end %>
</turbo-frame>
