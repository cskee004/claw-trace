<% content_for(:title) { "Agent Traces" } %>

<div class="traces-page">
  <div class="traces-header">
    <h1 class="page-title">Agent Traces</h1>
  </div>

  <form class="traces-filter" action="<%= traces_path %>" method="get">
    <label for="session_id">Session ID</label>
    <input type="text" id="session_id" name="session_id"
           value="<%= params[:session_id] %>"
           placeholder="Filter by agent.session.id…">
    <button type="submit">Filter</button>
    <% if params[:session_id].present? %>
      <%= link_to "Clear", traces_path, class: "traces-filter__clear" %>
    <% end %>
  </form>

  <% if flash[:notice] %>
    <p class="flash flash--notice"><%= flash[:notice] %></p>
  <% end %>
  <% if flash[:alert] %>
    <p class="flash flash--alert"><%= flash[:alert] %></p>
  <% end %>

  <% if @traces.empty? %>
    <p class="traces-empty">No traces recorded yet.</p>
  <% else %>
    <table class="traces-table">
      <thead>
        <tr>
          <th>Trace ID</th>
          <th>Agent</th>
          <th>Task</th>
          <th>Start Time</th>
          <th>Duration</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @traces.each do |trace| %>
          <tr>
            <td class="traces-table__trace-id">
              <%= link_to trace.trace_id, trace_path(trace), class: "traces-table__trace-link" %>
            </td>
            <td><%= trace.agent_id %></td>
            <td><%= trace.task_name %></td>
            <td><%= trace.start_time.strftime("%Y-%m-%d %H:%M:%S UTC") %></td>
            <td><%= format_duration(@durations[trace.trace_id]) %></td>
            <td>
              <span class="status-badge status-badge--<%= trace.status %>">
                <%= trace.status.tr("_", " ") %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
