<%# Locals: trace, spans (DFS-ordered array), span_latencies (hash), total_duration_ms %>

<%= turbo_frame_tag "trace-waterfall-#{trace.trace_id}" do %>
  <% if spans.empty? %>
    <p class="text-center py-12 text-sm font-light italic text-[var(--color-fg-subtle)]">
      No spans recorded for this trace.
    </p>
  <% else %>

    <%# ── Column header row ── %>
    <div class="grid grid-cols-[45%_1fr_64px] text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)] mb-1 px-3">
      <div>Span</div>
      <div>Timeline</div>
      <div class="text-right pr-2">Duration</div>
    </div>

    <% depths   = span_depth_map(spans) %>
    <% total_ms = total_duration_ms.to_f %>

    <%# ── Waterfall rows container — stable id for Turbo Streams append (Task 28) ── %>
    <div id="waterfall-rows-<%= trace.trace_id %>"
         class="rounded-lg overflow-hidden border border-[var(--color-surface-2)]">
      <% spans.each do |span| %>
        <%= render "span_row",
              span: span,
              depth: depths[span.span_id],
              latency: span_latencies[span.span_id],
              total_ms: total_ms,
              trace_start_time: trace.start_time %>
      <% end %>
    </div>

  <% end %>
<% end %>
