<%= turbo_stream_from "trace:#{@trace.trace_id}" %>
<% content_for(:title) { "#{@trace.task_name} — Trace" } %>
<% content_for(:breadcrumbs) do %>
  <nav class="flex items-center gap-2 text-sm">
    <%= link_to "Traces", traces_path, class: "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]" %>
    <span class="text-[var(--color-fg-subtle)] font-light">/</span>
    <span class="font-bold text-[var(--color-fg)] truncate"><%= @trace.task_name %></span>
  </nav>
<% end %>

<div class="p-4">

  <%# ── Title row ── %>
  <div class="flex items-center gap-3 mb-5">
    <h1 class="text-xl font-bold text-[var(--color-fg)]"><%= @trace.task_name %></h1>
    <span class="status-badge status-badge--<%= @trace.status %>
                 inline-block px-2 py-0.5 rounded text-xs font-bold tracking-wide capitalize">
      <%= @trace.status.tr("_", " ") %>
    </span>
  </div>

  <%= render "summary",
        trace: @trace,
        span_count: @spans.size,
        total_duration_ms: @total_duration_ms,
        estimated_cost_usd: @estimated_cost_usd %>

  <% if @compare_candidates.any? %>
    <div class="mt-4 bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg overflow-hidden">
      <div class="px-4 py-2.5 border-b border-[var(--color-surface-2)]">
        <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]">Compare with another trace</h2>
      </div>
      <div class="px-4 py-2.5">
        <%= form_with url: compare_traces_path, method: :get, class: "flex items-center gap-3" do |f| %>
          <%= f.hidden_field :a, value: @trace.trace_id %>
          <%= f.select :b,
                options_from_collection_for_select(@compare_candidates, :trace_id, ->(t) { "#{t.trace_id[0..7]} · #{t.status} · #{t.start_time.strftime('%b %-d %H:%M:%S')}" }),
                {},
                class: "bg-[var(--color-surface-2)] text-[var(--color-fg)] border border-[var(--color-surface-2)]
                        rounded px-2 py-1 text-xs font-mono flex-1 min-w-0" %>
          <%= f.submit "Compare →",
                class: "shrink-0 px-3 py-1 rounded text-xs font-bold
                        bg-[var(--color-surface-2)] text-[var(--color-fg)]
                        border border-[var(--color-surface-2)] cursor-pointer
                        hover:bg-[color-mix(in_srgb,var(--color-surface-2)_70%,var(--color-fg))]" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @spans.size == 1 %>
    <%= render "compact_span",
          span: @spans.first,
          latency: @span_latencies[@spans.first.span_id],
          total_duration_ms: @total_duration_ms,
          span_logs: (@logs_by_span_id || {}).fetch(@spans.first.span_id, []) %>
  <% else %>
    <%= render "waterfall",
          trace: @trace,
          spans: @spans,
          span_latencies: @span_latencies,
          total_duration_ms: @total_duration_ms,
          logs_by_span_id: @logs_by_span_id %>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
    <div class="bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4">
      <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Span Durations</h2>
      <turbo-frame id="trace_span_chart_<%= @trace.trace_id %>"
                   src="<%= span_chart_trace_path(@trace) %>"
                   loading="lazy">
        <div class="min-h-[180px] flex items-center justify-center
                    text-xs italic text-[var(--color-fg-subtle)]">Loading…</div>
      </turbo-frame>
    </div>
    <div class="bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg p-4">
      <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Tool Calls</h2>
      <turbo-frame id="trace_tool_calls_chart_<%= @trace.trace_id %>"
                   src="<%= tool_calls_chart_trace_path(@trace) %>"
                   loading="lazy">
        <div class="min-h-[300px] flex items-center justify-center
                    text-xs italic text-[var(--color-fg-subtle)]">Loading…</div>
      </turbo-frame>
    </div>
  </div>

  <div class="mt-6 bg-[var(--color-surface)] border border-[var(--color-surface-2)] rounded-lg overflow-hidden" id="logs">
    <div class="px-4 py-3 border-b border-[var(--color-surface-2)]">
      <h2 class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]">All Logs</h2>
    </div>
    <turbo-frame id="trace_all_logs_<%= @trace.trace_id %>"
                 src="<%= logs_trace_path(@trace, span_id: params[:span_id]) %>"
                 loading="lazy">
      <div class="min-h-[80px] flex items-center justify-center
                  text-xs italic text-[var(--color-fg-subtle)]">Loading…</div>
    </turbo-frame>
  </div>

</div>
