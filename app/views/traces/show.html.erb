<% content_for(:title) { "#{@trace.task_name} — Trace" } %>

<div class="p-4">

  <%# ── Back link + title row ── %>
  <div class="mb-5">
    <%= link_to "← All Traces", traces_path,
          class: "text-xs font-bold text-[var(--color-fg-subtle)] hover:text-[var(--color-fg)]" %>
    <div class="flex items-center gap-3 mt-2">
      <h1 class="text-xl font-bold text-[var(--color-fg)]"><%= @trace.task_name %></h1>
      <span class="status-badge status-badge--<%= @trace.status %>
                   inline-block px-2 py-0.5 rounded text-xs font-bold tracking-wide capitalize">
        <%= @trace.status.tr("_", " ") %>
      </span>
    </div>
  </div>

  <%# ── Meta strip ── %>
  <dl class="flex flex-wrap gap-6 bg-[var(--color-surface)] border border-[var(--color-surface-2)]
             rounded px-4 py-3 mb-5">
    <div class="flex flex-col gap-0.5">
      <dt class="text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)]">Trace ID</dt>
      <dd class="font-mono font-light text-xs text-[var(--color-fg-muted)] m-0"><%= @trace.trace_id %></dd>
    </div>
    <div class="flex flex-col gap-0.5">
      <dt class="text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)]">Agent</dt>
      <dd class="font-mono font-light text-xs text-[var(--color-fg-muted)] m-0"><%= @trace.agent_id %></dd>
    </div>
    <div class="flex flex-col gap-0.5">
      <dt class="text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)]">Started</dt>
      <dd class="font-mono font-light text-xs text-[var(--color-fg-muted)] m-0">
        <%= @trace.start_time.strftime("%Y-%m-%d %H:%M:%S UTC") %>
      </dd>
    </div>
    <div class="flex flex-col gap-0.5">
      <dt class="text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)]">Duration</dt>
      <dd class="font-mono font-light text-xs text-[var(--color-fg-muted)] m-0">
        <%= format_duration(@total_duration_ms) %>
      </dd>
    </div>
    <div class="flex flex-col gap-0.5">
      <dt class="text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)]">Spans</dt>
      <dd class="font-mono font-light text-xs text-[var(--color-fg-muted)] m-0"><%= @spans.size %></dd>
    </div>
  </dl>

  <% if @spans.empty? %>
    <p class="text-center py-12 text-sm font-light italic text-[var(--color-fg-subtle)]">
      No spans recorded for this trace.
    </p>
  <% else %>

    <%# ── Column header row ── %>
    <div class="flex text-[10px] uppercase tracking-wider font-bold text-[var(--color-fg-subtle)] mb-1 px-3">
      <div class="w-[45%]">Span</div>
      <div class="flex-1">Timeline</div>
    </div>

    <% depths   = span_depth_map(@spans) %>
    <% total_ms = @total_duration_ms.to_f %>

    <%# ── Waterfall rows ── %>
    <div class="rounded-lg overflow-hidden border border-[var(--color-surface-2)]">
      <% @spans.each do |span| %>
        <%= render "span_row",
              span: span,
              depth: depths[span.span_id],
              latency: @span_latencies[span.span_id],
              total_ms: total_ms,
              trace_start_time: @trace.start_time %>
      <% end %>
    </div>

  <% end %>
</div>
