<%# Locals: span, depth (integer), latency (ms float or nil),
             total_ms (float), trace_start_time (Time) %>

<% if total_ms > 0 %>
  <% offset_ms      = (span.timestamp.to_f - trace_start_time.to_f) * 1000.0 %>
  <% raw_offset_pct = (offset_ms / total_ms * 100).clamp(0.0, 100.0) %>
  <% offset_pct     = raw_offset_pct.round(4) %>
  <% width_pct      = latency ? (latency / total_ms * 100).clamp(0.0, 100.0 - raw_offset_pct).round(4) : 0 %>
<% else %>
  <% offset_pct = 0; width_pct = 0 %>
<% end %>

<div class="border-b border-[var(--color-surface-2)] last:border-0 bg-[var(--color-surface)]"
     data-controller="span-detail">

  <%# ── Clickable row: label col + bar col ── %>
  <button type="button"
          class="w-full grid grid-cols-[45%_1fr_64px] items-center min-h-[2.5rem] text-left cursor-pointer
                 hover:bg-[var(--color-row-hover)] focus-visible:outline-none focus-visible:bg-[var(--color-row-hover)]"
          data-action="click->span-detail#toggle"
          aria-expanded="true">

    <%# Label column (45%) — indented by parent depth %>
    <div class="flex items-center gap-2 py-2 pr-3 overflow-hidden min-w-0"
         style="padding-left: calc(0.75rem + <%= depth * 16 %>px)">
      <span class="text-[10px] text-[var(--color-fg-subtle)] shrink-0 select-none"
            data-span-detail-target="chevron">▾</span>
      <span class="span-type-badge span-type-badge--<%= span.span_type %> shrink-0">
        <%= span.span_type.tr("_", " ") %>
      </span>
      <% if span.span_name.present? %>
        <span class="font-mono font-light text-xs text-[var(--color-fg-muted)] truncate"
              title="<%= span.span_name %>">
          <%= span.span_name %>
        </span>
      <% end %>
      <span class="font-mono font-light text-[10px] text-[var(--color-fg-subtle)] ml-auto shrink-0">
        <%= span.timestamp.strftime("%H:%M:%S.%3N") %>
      </span>
    </div>

    <%# Bar column (1fr) — bar positioned absolutely within the container %>
    <div class="relative h-10">
      <% if total_ms > 0 %>
        <div class="absolute inset-0 flex items-center">
          <div class="absolute h-2 rounded-sm waterfall-bar--<%= span.span_type %>"
               style="left: <%= offset_pct %>%;
                      width: <%= width_pct %>%">
          </div>
        </div>
      <% end %>
    </div>

    <%# Duration column (64px fixed gutter) %>
    <% if latency %>
      <span class="font-mono text-xs text-[var(--color-fg-muted)] text-right pr-2">
        <%= format_duration(latency) %>
      </span>
    <% end %>

  </button><%# end clickable row %>

  <%# ── Metadata drawer (collapsed; expands via Stimulus toggle) ── %>
  <div class="waterfall-drawer bg-[var(--color-bg)]"
       data-span-detail-target="drawer">
    <div class="pr-4 py-3"
         style="padding-left: calc(0.75rem + <%= depth * 16 %>px)">

      <%# ── Outcome pill ── %>
      <% if span.span_outcome.present? %>
        <div class="mb-3">
          <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide
                       <%= span.span_outcome == 'error' ? 'bg-[color-mix(in_srgb,var(--color-error-fg)_15%,transparent)] text-[var(--color-error-fg)]'
                                                        : 'bg-[color-mix(in_srgb,var(--color-success-fg)_15%,transparent)] text-[var(--color-success-fg)]' %>">
            <%= span.span_outcome %>
          </span>
        </div>
      <% end %>

      <%# ── First-class LLM call section (model_call and agent_turn spans) ── %>
      <% if %w[model_call agent_turn].include?(span.span_type) && (span.span_model || span.span_input_tokens) %>
        <div class="mb-3 pb-3 border-b border-[var(--color-surface-2)]">
          <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] mb-2">LLM call</p>
          <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-1">
            <% if span.span_model.present? %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Model</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= span.span_model %></dd>
            <% end %>
            <% if span.span_provider.present? %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Provider</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= span.span_provider %></dd>
            <% end %>
            <% if span.span_input_tokens %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Input tokens</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= number_with_delimiter(span.span_input_tokens) %></dd>
            <% end %>
            <% if span.span_output_tokens %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Output tokens</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= number_with_delimiter(span.span_output_tokens) %></dd>
            <% end %>
            <% if span.span_cache_read_tokens %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Cache read</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= number_with_delimiter(span.span_cache_read_tokens) %></dd>
            <% end %>
            <% if span.span_cache_write_tokens %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Cache write</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= number_with_delimiter(span.span_cache_write_tokens) %></dd>
            <% end %>
            <% if span.span_total_tokens %>
              <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] whitespace-nowrap">Total tokens</dt>
              <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] m-0"><%= number_with_delimiter(span.span_total_tokens) %></dd>
            <% end %>
          </dl>
        </div>
      <% end %>

      <%# ── Generic metadata dump (attributes not surfaced above) ── %>
      <% residual = (span.metadata || {}).reject { |k, _| k.to_s.start_with?("openclaw.model", "openclaw.provider", "openclaw.tokens", "openclaw.outcome", "gen_ai.usage.") } %>
      <% if residual.present? %>
        <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-1">
          <% residual.each do |key, value| %>
            <dt class="text-[11px] font-bold text-[var(--color-fg-subtle)] capitalize whitespace-nowrap">
              <%= key.to_s.tr("_.", " ") %>
            </dt>
            <dd class="font-mono font-light text-[11px] text-[var(--color-fg-muted)] break-all m-0">
              <%= value %>
            </dd>
          <% end %>
        </dl>
      <% elsif !span.metadata.present? %>
        <p class="text-xs font-light italic text-[var(--color-fg-subtle)]">No metadata.</p>
      <% end %>

      <% span_logs = local_assigns.fetch(:span_logs, []) %>
      <% if span_logs.any? %>
        <div class="mt-3 pt-3 border-t border-[var(--color-surface-2)]">
          <p class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] mb-2">
            Logs (<%= span_logs.size %>)
          </p>
          <div class="space-y-1.5">
            <% span_logs.each do |log| %>
              <% pretty_body = begin; JSON.pretty_generate(JSON.parse(log.body)); rescue; log.body; end %>
              <% is_json = pretty_body != log.body %>
              <div class="rounded bg-[var(--color-bg)] border border-[var(--color-surface-2)] px-2.5 py-1.5">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-mono text-[10px] text-[var(--color-fg-subtle)] shrink-0">
                    <%= log.timestamp&.strftime("%H:%M:%S.%3N") %>
                  </span>
                  <span class="severity-badge <%= severity_badge_class(log.severity_text) %> shrink-0">
                    <%= log.severity_text || "?" %>
                  </span>
                </div>
                <% if is_json %>
                  <details class="group">
                    <summary class="cursor-pointer list-none flex items-center gap-1 select-none">
                      <span class="text-[var(--color-fg-subtle)] text-[10px] group-open:rotate-90 transition-transform inline-block shrink-0">▶</span>
                      <span class="font-mono text-[11px] text-[var(--color-fg-muted)] truncate"><%= truncate(log.body, length: 80) %></span>
                    </summary>
                    <pre class="mt-1.5 p-2 rounded bg-[color-mix(in_srgb,var(--color-bg)_50%,transparent)]
                                font-mono text-[11px] text-[var(--color-fg)] overflow-x-auto whitespace-pre-wrap
                                break-words leading-relaxed border border-[var(--color-surface-2)]"><%= pretty_body %></pre>
                  </details>
                <% else %>
                  <span class="font-mono text-[11px] text-[var(--color-fg-muted)] break-all"><%= log.body %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

</div><%# end span-detail controller root %>
