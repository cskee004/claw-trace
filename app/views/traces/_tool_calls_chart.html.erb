<%# app/views/traces/_tool_calls_chart.html.erb %>
<turbo-frame id="trace_tool_calls_chart_<%= @trace.trace_id %>">
  <% if @chart_options.any? %>
    <div class="min-h-[300px]"
         data-controller="apex-chart"
         data-apex-chart-options-value="<%= json_escape(@chart_options.to_json) %>">
    </div>
  <% else %>
    <p class="text-xs italic text-[var(--color-fg-subtle)] py-4">No tool calls recorded for this trace.</p>
  <% end %>
</turbo-frame>
