<%# app/views/traces/_span_chart.html.erb %>
<turbo-frame id="trace_span_chart_<%= @trace.trace_id %>">
  <% if @chart_options[:series].present? %>
    <div data-controller="apex-chart"
         data-apex-chart-options-value="<%= json_escape(@chart_options.to_json) %>">
    </div>
  <% else %>
    <p class="text-xs italic text-[var(--color-fg-subtle)] py-4">No span data available.</p>
  <% end %>
</turbo-frame>
