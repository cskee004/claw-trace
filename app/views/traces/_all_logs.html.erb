<%= turbo_frame_tag "trace_all_logs_#{trace_id}" do %>
<% if subsystems.any? || (defined?(span_id) && span_id.present?) %>
  <form class="flex items-center gap-2 flex-wrap px-4 py-2 border-b border-[var(--color-surface-2)]"
        action="<%= logs_trace_path(trace_id) %>" method="get">
    <%# Preserve span_id across subsystem filter changes %>
    <% if defined?(span_id) && span_id.present? %>
      <input type="hidden" name="span_id" value="<%= span_id %>">
    <% end %>
    <% if subsystems.any? %>
      <label class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-fg-subtle)]"
             for="all_logs_subsystem_<%= trace_id %>">Subsystem</label>
      <select name="subsystem" id="all_logs_subsystem_<%= trace_id %>"
              class="text-sm bg-[var(--color-surface)] border border-[var(--color-surface-2)]
                     text-[var(--color-fg)] rounded px-2 py-1
                     focus:outline-none focus:border-[var(--color-accent)]"
              onchange="this.form.requestSubmit()">
        <option value="">All</option>
        <% subsystems.each do |sub| %>
          <option value="<%= sub %>" <%= "selected" if subsystem == sub %>><%= sub %></option>
        <% end %>
      </select>
      <% if subsystem.present? %>
        <%= link_to "Clear", logs_trace_path(trace_id, span_id: span_id.presence),
              class: "text-xs text-[var(--color-fg-subtle)] hover:text-[var(--color-fg)]" %>
      <% end %>
    <% end %>
    <% if defined?(span_id) && span_id.present? %>
      <span class="text-[10px] text-[var(--color-fg-subtle)]">· filtered to span</span>
      <%= link_to "Clear", logs_trace_path(trace_id, subsystem: subsystem.presence),
            class: "text-xs text-[var(--color-fg-subtle)] hover:text-[var(--color-fg)]" %>
    <% end %>
  </form>
<% end %>
<% if logs.empty? %>
  <p class="px-4 py-8 text-sm italic text-center text-[var(--color-fg-subtle)]">
    No logs recorded for this trace.
  </p>
<% else %>
  <table class="w-full border-collapse bg-[var(--color-surface)]">
    <thead>
      <tr>
        <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)] whitespace-nowrap">Timestamp</th>
        <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Severity</th>
        <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Message</th>
        <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Span</th>
      </tr>
    </thead>
    <tbody>
      <% logs.each do |log| %>
        <% pretty_body = begin; JSON.pretty_generate(JSON.parse(log.body)); rescue; log.body; end %>
        <% is_json = pretty_body != log.body %>
        <tr class="border-b border-[var(--color-surface-2)] last:border-0 align-top"
            onmouseover="this.style.backgroundColor='var(--color-row-hover)'"
            onmouseout="this.style.backgroundColor=''">
          <td class="px-4 py-2.5 font-mono text-[11px] text-[var(--color-fg-subtle)] whitespace-nowrap">
            <%= log.timestamp&.strftime("%H:%M:%S.%3N") %>
          </td>
          <td class="px-4 py-2.5">
            <span class="severity-badge <%= severity_badge_class(log.severity_text) %>">
              <%= log.severity_text || "?" %>
            </span>
          </td>
          <td class="px-4 py-2.5 text-xs text-[var(--color-fg)] max-w-xl">
            <% if is_json %>
              <details class="group">
                <summary class="cursor-pointer list-none flex items-center gap-1.5 select-none">
                  <span class="text-[var(--color-fg-subtle)] text-[10px] group-open:rotate-90 transition-transform inline-block">▶</span>
                  <span class="font-mono text-[var(--color-fg-muted)] truncate"><%= truncate(log.body, length: 100) %></span>
                </summary>
                <pre class="mt-2 p-3 rounded bg-[var(--color-bg)] border border-[var(--color-surface-2)]
                            font-mono text-[11px] text-[var(--color-fg)] overflow-x-auto whitespace-pre-wrap break-words
                            leading-relaxed"><%= pretty_body %></pre>
              </details>
            <% else %>
              <span class="font-mono text-[var(--color-fg-muted)]"><%= log.body %></span>
            <% end %>
          </td>
          <td class="px-4 py-2.5 font-mono text-xs text-[var(--color-fg-muted)]">
            <%= log.span_id || "—" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p class="px-4 py-2 text-xs text-[var(--color-fg-subtle)] text-right border-t border-[var(--color-surface-2)]">
    Showing <%= logs.size %> record<%= logs.size == 1 ? "" : "s" %>
  </p>
<% end %>
<% end %>
