<% content_for(:title) { "Agent Inventory" } %>

<div class="p-4">
  <h1 class="text-xl font-bold text-[var(--color-fg)] mb-5">Agent Inventory</h1>

  <%# ── Period filter ── %>
  <div class="flex items-center gap-2 flex-wrap mb-5"
       data-controller="dashboard-filter">
    <% [["12h", "12h"], ["24h", "24h"], ["7d", "7d"], ["30d", "30d"]].each do |period, label| %>
      <%= link_to label, agents_path(period: period),
            class: "filter-btn #{'filter-btn--active' if @current_period == period}" %>
    <% end %>
    <button type="button"
            class="filter-btn <%= 'filter-btn--active' if @current_period == 'custom' %>"
            data-action="click->dashboard-filter#showCustom">
      Custom
    </button>

    <form data-dashboard-filter-target="customForm"
          <%= @current_period == "custom" ? "" : "hidden" %>
          action="<%= agents_path %>" method="get"
          class="flex items-center gap-2">
      <input type="hidden" name="period" value="custom">
      <input type="date" name="from" value="<%= params[:from] %>"
             class="date-input" required>
      <span class="text-xs text-[var(--color-fg-subtle)]">to</span>
      <input type="date" name="to" value="<%= params[:to] %>"
             class="date-input" required>
      <button type="submit" class="filter-btn">Apply</button>
    </form>
  </div>

  <% if @agents.empty? %>
    <p class="text-center py-12 text-sm italic text-[var(--color-fg-subtle)]">
      No agents recorded yet.
    </p>
  <% else %>
    <div class="rounded-lg overflow-hidden border border-[var(--color-surface-2)]">
      <table class="w-full border-collapse bg-[var(--color-surface)]">
        <thead>
          <tr>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Agent ID</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Runs</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Successes</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Errors</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Error Rate</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Avg Duration</th>
            <th class="text-xs font-bold uppercase tracking-wider text-[var(--color-fg-subtle)] px-4 py-2.5 text-left bg-[var(--color-bg)] border-b border-[var(--color-surface-2)]">Last Seen</th>
          </tr>
        </thead>
        <tbody>
          <% @agents.each do |agent| %>
            <tr class="border-b border-[var(--color-surface-2)] last:border-0"
                onmouseover="this.style.backgroundColor='var(--color-row-hover)'"
                onmouseout="this.style.backgroundColor=''">
              <td class="px-4 py-2.5 align-middle">
                <%= link_to agent.agent_id, agent_path(agent.agent_id),
                      class: "font-mono text-xs text-[var(--color-accent)] hover:underline" %>
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs text-[var(--color-fg-muted)]">
                <%= agent.total_runs %>
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs text-[var(--color-success-fg)]">
                <%= agent.success_count %>
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs
                         <%= agent.error_count > 0 ? 'text-[var(--color-span-error)]' : 'text-[var(--color-fg-muted)]' %>">
                <%= agent.error_count %>
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs
                         <%= agent.error_rate > 0 ? 'text-[var(--color-span-error)]' : 'text-[var(--color-fg-muted)]' %>">
                <%= agent.error_rate %>%
              </td>
              <td class="px-4 py-2.5 align-middle font-mono text-xs text-[var(--color-fg-muted)]">
                <%= format_duration(agent.avg_duration_ms) %>
              </td>
              <td class="px-4 py-2.5 align-middle text-xs text-[var(--color-fg-muted)]">
                <%= agent.last_seen ? format_time_relative(agent.last_seen) : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
